{
  "name": "kubecmds-viz",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "concurrently \"tsx api/index.js\" \"ng serve\"",
    "dev:go": "concurrently \"PROJECT_ROOT=$PWD go -C cmd/server run .\" \"ng serve\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:utils": "tsx --test api/utils/**/*.spec.ts",
    "test:utils:cov": "npx c8 --include='api/utils/*.ts' --exclude='api/utils/*.spec.ts' --exclude='api/utils/test-fixtures.ts' tsx --test 'api/utils/**/*.spec.ts'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshot": "playwright test e2e/screenshots.spec.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.2.4",
    "@angular/cdk": "^20.2.1",
    "@angular/common": "^20.2.4",
    "@angular/compiler": "^20.2.4",
    "@angular/core": "^20.2.4",
    "@angular/forms": "^20.2.4",
    "@angular/material": "^20.2.2",
    "@angular/platform-browser": "^20.2.4",
    "@angular/router": "^20.2.4",
    "@cosmograph/cosmos": "^1.6.1",
    "@tailwindcss/postcss": "^4.1.12",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.2.2",
    "@angular/cli": "^20.2.2",
    "@angular/compiler-cli": "^20.2.4",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
